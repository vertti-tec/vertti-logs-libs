{
    "name": "vertti/vertti-logs",
    "description": "SDK para envio de logs ao Vertti Logs.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Vertti\\Logs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vertti\\Logs\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}